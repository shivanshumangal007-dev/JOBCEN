{
  "manifest_version": 3,
  "name": "JOBCEN - dev",
  "version": "0.1",
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://wellfound.com/*"
  ],
  "content_scripts": [
    {
      "js": [
        "assets/wellfound_fillers.ts-loader-BhNE0LK3.js"
      ],
      "matches": [
        "https://wellfound.com/profile/edit*"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://wellfound.com/*"
      ],
      "resources": [
        "assets/rolldown-runtime-D9-fqq9M.js",
        "assets/wellfound_fillers.ts-Cu6Bru7G.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
