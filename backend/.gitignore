# pyenv
#   For a library or package, you might want to comit your .python-version file.
#   For an app, you might want to ignore it.
# .python-version

# pipenv
#   According to pypa/pipenv#1173, it is a good idea to include Pipfile.lock in version control.
#   But if you should be running with development dependencies, you can ignore it.
#Pipfile.lock

# poetry
#   Using Poetry, it's generally recommended to commit poetry.lock into version control.
#Poetry.lock

# pdm
#   Using PDM, it is advised to commit pdm.lock into version control
#pdm.lock
#   pdm build packge
.pdm-plugins/

